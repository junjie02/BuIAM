# BuIAM 本地环境变量示例
# 复制为 .env 后按需修改；不要把真实密钥提交到仓库。
# 当前业务 Agent 动作默认仍使用 mock provider，认证、授权、委托链、意图链和审计链路是真实执行。


# =========================
# 基础运行配置
# =========================

# Gateway 对外访问地址。脚本会从这里解析自启动端口。
BUIAM_GATEWAY_URL=http://127.0.0.1:8000

# Demo 用户 ID；root token、root intent 和 root credential 默认使用这个用户。
BUIAM_DEMO_USER_ID=user_123

# Demo 结束后是否保留脚本启动的 Gateway/Agent 进程。
# 0：脚本结束时关闭服务；1：保留服务，方便继续手工调接口。
BUIAM_DEMO_KEEP_SERVERS=0

# SQLite 审计与安全链路数据库路径。
BUIAM_DB_PATH=data/audit.db

# 开发版 RSA key 存储目录。
BUIAM_KEY_DIR=data/keys


# =========================
# Agent 注册与服务地址
# =========================

# Gateway 启动时会把这三个 endpoint 注册到 agent registry。
# 如果三个 Agent 分别跑在不同机器或端口，改这里即可。
DOC_AGENT_ENDPOINT=http://127.0.0.1:8011/a2a/tasks
ENTERPRISE_DATA_AGENT_ENDPOINT=http://127.0.0.1:8012/a2a/tasks
EXTERNAL_SEARCH_AGENT_ENDPOINT=http://127.0.0.1:8013/a2a/tasks

# 可选：给 SDK 预置 Agent Bearer token。
# 为空时，SDK 会向 Gateway 的 /identity/tokens 自动申请 agent token。
DOC_AGENT_ACCESS_TOKEN=
ENTERPRISE_DATA_AGENT_ACCESS_TOKEN=
EXTERNAL_SEARCH_AGENT_ACCESS_TOKEN=

# SDK 自动申请 agent token 时使用的最大 TTL，最终不会超过当前授权上下文剩余时间。
A2A_AGENT_TOKEN_TTL_SECONDS=3600

# Gateway 转发 A2A 请求到目标 Agent 的 HTTP 超时时间。
# sleep / 长任务 demo 如果经常超时，可以适当调大。
A2A_FORWARD_TIMEOUT_SECONDS=30


# =========================
# LLM 与意图链 Provider
# =========================

# 全局默认 LLM provider。
# mock：确定性本地 mock，不需要密钥；openai / anthropic：调用真实兼容接口。
LLM_PROVIDER=mock

# 意图生成 provider。未单独配置时会回退到 LLM_PROVIDER。
INTENT_GENERATOR_PROVIDER=mock

# 意图漂移 judge provider。未单独配置时会回退到 LLM_PROVIDER。
INTENT_JUDGE_PROVIDER=mock

# OpenAI 兼容接口配置；仅当 provider 选择 openai 时需要。
OPENAI_BASE_URL=https://api.minimaxi.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=MiniMax-M2.7

# Anthropic 兼容接口配置；仅当 provider 选择 anthropic 时需要。
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-haiku-latest


# =========================
# 安全验证脚本参数
# =========================

# verify_token_lifecycle.py 中“过期 token 阻止新请求”的 token TTL。
BUIAM_SECURITY_EXPIRED_TOKEN_TTL_SECONDS=1

# 申请短 token 后等待多久再发新请求；必须大于上面的 TTL 才能稳定触发过期。
BUIAM_SECURITY_EXPIRED_TOKEN_WAIT_SECONDS=1.2

# “自然过期不取消已开始任务”的 token TTL。
# 注意：这个值不能太短，否则 HTTP 请求还没进入 Gateway，token 就已经过期，请求会在启动前被拒绝。
BUIAM_SECURITY_NATURAL_EXPIRY_TOKEN_TTL_SECONDS=2

# “自然过期不取消已开始任务”的 sleep 秒数。
# 应大于 NATURAL_EXPIRY_TOKEN_TTL_SECONDS，用来证明任务开始后 token 自然过期也不会被主动 cancel。
BUIAM_SECURITY_NATURAL_EXPIRY_SLEEP_SECONDS=2.5

# “吊销会取消运行中任务”的 sleep 秒数。
BUIAM_SECURITY_REVOKE_SLEEP_SECONDS=8

# sleep 任务发出后等待多久再 revoke token。
# 需要给 Gateway 一点时间把任务注册到进程内 task registry。
BUIAM_SECURITY_REVOKE_DELAY_SECONDS=0.5

# 安全验证脚本中普通长效 token 的 TTL。
BUIAM_SECURITY_LONG_TOKEN_TTL_SECONDS=3600
