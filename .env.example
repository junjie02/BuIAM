# BuIAM local environment configuration
# Copy real API keys into this file only for local development.
# Do not commit real secrets.

# Demo Agent report-generation LLM provider.
# Options: mock | openai | anthropic
LLM_PROVIDER=anthropic

# Intent drift judge provider.
# Options: openai | anthropic
# Note: when an intent_node is present, the gateway calls this provider.
# If the selected provider has no API key, intent checks fail closed with INTENT_JUDGE_FAILED.
INTENT_JUDGE_PROVIDER=openai

# OpenAI-compatible settings used by app/intent/judge.py and examples/llm/client.py.
# For third-party OpenAI-compatible providers, set OPENAI_BASE_URL, for example:
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic-compatible settings used by app/intent/judge.py and examples/llm/client.py.
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Feishu OpenAPI settings used by example/agent/enterprise_data_agent.py.
FEISHU_BASE_URL=https://open.feishu.cn/open-apis
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_TIMEOUT_SECONDS=30
FEISHU_CONTACT_DEPARTMENT_ID=
FEISHU_CONTACT_DEPARTMENT_ID_TYPE=open_department_id
FEISHU_CONTACT_USER_ID_TYPE=open_id
FEISHU_CALENDAR_ID=
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_TABLE_ID=
FEISHU_BITABLE_VIEW_ID=
FEISHU_DOC_FOLDER_TOKEN=
FEISHU_DOC_WEB_BASE_URL=
